{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Real-time sensor readings, alert levels, and failure detection across all plant assets.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Plant Status",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "HEALTHY" }, "1": { "text": "WARNING" }, "2": { "text": "CRITICAL" } }, "type": "value" }
          ],
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Critical Assets",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT asset_id) AS value FROM sensor_readings WHERE time > NOW() - INTERVAL '5 minutes' AND alert_level = 'CRITICAL'",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Warning Assets",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT asset_id) AS value FROM sensor_readings WHERE time > NOW() - INTERVAL '5 minutes' AND alert_level = 'WARNING'",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Failures",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "table",
          "rawSql": "SELECT COUNT(DISTINCT asset_id) AS value FROM sensor_readings WHERE time > NOW() - INTERVAL '15 minutes' AND is_failure = TRUE",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "green", "value": 72 }
            ]
          },
          "unit": "h",
          "noValue": "—"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Min RUL (hours)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "table",
          "rawSql": "SELECT ROUND(MIN(rul_hours)::numeric, 1) AS value FROM sensor_readings WHERE time > NOW() - INTERVAL '15 minutes' AND rul_hours IS NOT NULL",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Alerts (last 1h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS value FROM sensor_readings WHERE time > NOW() - INTERVAL '1 hour' AND alert_level IN ('WARNING','CRITICAL')",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Turbine Sensors",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1.5, "fillOpacity": 8, "spanNulls": true },
          "unit": "velocityms",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 4.5 },
            { "color": "red", "value": 7.1 }
          ]},
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Turbine Vibration (mm/s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "time_series",
          "rawSql": "SELECT time_bucket('5 minutes', time) AS time, asset_id || ' · ' || sensor AS metric, AVG(value) AS value FROM sensor_readings WHERE $__timeFilter(time) AND asset_type = 'turbine' AND sensor LIKE 'vibration%' AND value IS NOT NULL GROUP BY 1,2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1.5, "fillOpacity": 8, "spanNulls": true },
          "unit": "celsius",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 85 },
            { "color": "red", "value": 95 }
          ]},
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Turbine Bearing Temperature (°C)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "time_series",
          "rawSql": "SELECT time_bucket('5 minutes', time) AS time, asset_id AS metric, AVG(value) AS value FROM sensor_readings WHERE $__timeFilter(time) AND asset_type = 'turbine' AND sensor = 'temperature_bearing' AND value IS NOT NULL GROUP BY 1,2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1.5, "fillOpacity": 8, "spanNulls": true },
          "unit": "rpm",
          "min": 2800, "max": 3300
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Turbine Rotation Speed (RPM)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "time_series",
          "rawSql": "SELECT time_bucket('5 minutes', time) AS time, asset_id AS metric, AVG(value) AS value FROM sensor_readings WHERE $__timeFilter(time) AND asset_type = 'turbine' AND sensor = 'rotation_speed' AND value IS NOT NULL GROUP BY 1,2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1.5, "fillOpacity": 8, "spanNulls": true },
          "unit": "pressurebar",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 2.5 },
            { "color": "green", "value": 3.0 }
          ]},
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Lube Oil Pressure (bar)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "time_series",
          "rawSql": "SELECT time_bucket('5 minutes', time) AS time, asset_id AS metric, AVG(value) AS value FROM sensor_readings WHERE $__timeFilter(time) AND asset_type = 'turbine' AND sensor = 'lube_oil_pressure' AND value IS NOT NULL GROUP BY 1,2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Compressor & Pump Sensors",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1.5, "fillOpacity": 8, "spanNulls": true },
          "unit": "velocityms",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Compressor & Pump Vibration (mm/s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "time_series",
          "rawSql": "SELECT time_bucket('5 minutes', time) AS time, asset_id AS metric, AVG(value) AS value FROM sensor_readings WHERE $__timeFilter(time) AND asset_type IN ('compressor','pump') AND sensor = 'vibration' AND value IS NOT NULL GROUP BY 1,2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1.5, "fillOpacity": 8, "spanNulls": true },
          "unit": "percentunit",
          "min": 0, "max": 1.5
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Motor Current (p.u.)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "time_series",
          "rawSql": "SELECT time_bucket('5 minutes', time) AS time, asset_id AS metric, AVG(value) AS value FROM sensor_readings WHERE $__timeFilter(time) AND asset_type IN ('compressor','pump') AND sensor = 'motor_current' AND value IS NOT NULL GROUP BY 1,2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Alert & Failure Log",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "alert_level" },
            "properties": [{ "id": "custom.width", "value": 100 },
              { "id": "mappings", "value": [
                { "options": { "CRITICAL": { "color": "red", "index": 0 }, "WARNING": { "color": "yellow", "index": 1 }, "NORMAL": { "color": "green", "index": 2 } }, "type": "value" }
              ]},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          { "matcher": { "id": "byName", "options": "time" }, "properties": [{ "id": "custom.width", "value": 160 }] },
          { "matcher": { "id": "byName", "options": "value" }, "properties": [{ "id": "custom.width", "value": 90 }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "id": 30,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "displayName": "time", "desc": true }] },
      "title": "Recent Alerts (WARNING / CRITICAL)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb-uid" },
          "format": "table",
          "rawSql": "SELECT time, asset_id, sensor, ROUND(value::numeric,3) AS value, unit, alert_level, failure_name, ROUND(rul_hours::numeric,1) AS rul_hours FROM sensor_readings WHERE $__timeFilter(time) AND alert_level IN ('WARNING','CRITICAL') ORDER BY time DESC LIMIT 200",
          "refId": "A"
        }
      ]
    }

  ],

  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["energy", "sensors", "operations"],
  "templating": {
    "list": [
      {
        "current": {},
