        "includeAll": true,
        "multi": true,
        "name": "asset",
        "options": [],
        "query": "SELECT DISTINCT asset_id FROM assets ORDER BY asset_id",
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Asset"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
